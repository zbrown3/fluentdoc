{
  "name": "fluentdoc-desktop",
  "version": "0.1.3",
  "private": true,
  "description": "FluentDoc desktop application (Electron)",
  "author": "Patrick Gaston",
  "main": "main.js",
  "scripts": {
    "start": "node start.js",
    "electron": "electron .",
    "bundle-jre": "node ../scripts/download-desktop-jre.mjs",
    "prepare-desktop-runtime": "node ../scripts/extract-sqlite-native.mjs && node ../scripts/strip-sqlite-from-app-jar.mjs",
    "predist": "npm run prepare-desktop-runtime",
    "predist:mac": "npm run prepare-desktop-runtime",
    "dist": "electron-builder --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:linux": "electron-builder --linux --publish never"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "publish": null,
    "appId": "com.fluentdoc.app",
    "productName": "FluentDoc",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "icon": "build/icon.png",
    "files": [
      "**/*",
      "!runtime/**",
      "!release/**"
    ],
    "extraResources": [
      {
        "from": "runtime/service",
        "to": "service",
        "filter": ["app.jar"]
      },
      {
        "from": "../apps/client/dist/fluentdoc-client/browser",
        "to": "web"
      },
      {
        "from": "runtime/jre",
        "to": "runtime/jre"
      },
      {
        "from": "runtime/native/sqlite",
        "to": "runtime/native/sqlite"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "signIgnore": [
        "^/Contents/Resources/web/.*",
        "^/Contents/Resources/service/app\\.jar$"
      ],
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": {
        "teamId": "F7D5P278QS"
      }
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "deb"
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "nsis": {
      "differentialPackage": false
    }
  }
}
