{
  "name": "fluentdoc-client",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve & npm run watch:bs-css",
    "build:test": "ng build --configuration test --aot",
    "build:prod": "ng build --configuration production --aot",
    "build:desktop": "ng build --configuration desktop --aot --base-href ./ --deploy-url ./",
    "watch:bs-css": "sass --watch src/scss/custom.scss src/css/custom.css",
    "compile:bs-css": "sass src/scss/custom.scss src/css/custom.css",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@abacritt/angularx-social-login": "^2.2.0",
